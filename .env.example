NODE_ENV=development
PORT=5000

DATABASE_URL=postgresql://user:password@localhost:5432/phi
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRY=7d

CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Gmail SMTP (use an App Password, not your real password)
# Enable 2FA on your Google account, then generate an App Password at:
# https://myaccount.google.com/apppasswords
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Google OAuth (create at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

GROQ_API_KEY=your_groq_api_key

LOG_LEVEL=debug
